# ============================================================================
#  Trading Platform — environment template. Copy to `.env` and fill in.
#  NEVER commit a real .env (gitleaks blocks it). Values here are safe defaults.
# ============================================================================

# --- App ---
APP_ENV=local                       # local | staging | production
APP_NAME=trading-platform
LOG_LEVEL=INFO
LOG_JSON=false                      # true in prod; pretty console locally

# --- Security ---
# Secret used to sign CSRF tokens / misc. Generate: python -c "import secrets;print(secrets.token_urlsafe(48))"
APP_SECRET_KEY=dev-only-change-me-please
COOKIE_SECURE=false                 # true in prod (HTTPS only)
COOKIE_DOMAIN=
SESSION_TTL_SECONDS=1209600         # 14 days
# 32-byte key (base64) for encrypting broker credentials at rest (libsodium secretbox).
# Generate: python -c "import base64,nacl.utils;print(base64.b64encode(nacl.utils.random(32)).decode())"
BROKER_CRED_KEY=
# Shared secret for the POST /internal/tick cron endpoint (only needed on free PaaS
# hosts without a background worker; empty = endpoint disabled).
TICK_SECRET=

# --- CORS (credentialed allowlist — NO wildcard) ---
CORS_ALLOW_ORIGINS=http://localhost:3000

# --- Database (PostgreSQL + TimescaleDB) ---
# Container maps to host 55432 (avoids clashing with a native PostgreSQL on 5432).
DATABASE_URL=postgresql+asyncpg://trading:trading@localhost:55432/trading

# --- Redis (cache / pub-sub / sessions / rate-limit / ARQ) ---
REDIS_URL=redis://localhost:56379/0

# --- Rate limiting / request size ---
RATE_LIMIT_PER_MINUTE=120
MAX_REQUEST_BYTES=2000000           # reject larger request bodies with 413 (DoS guard)

# --- Observability ---
SENTRY_DSN=
# Bearer token required to scrape /metrics (Prometheus sends Authorization: Bearer <token>).
# Empty = /metrics returns 404 (fail-closed). Add the same token to infra/prometheus.yml.
METRICS_TOKEN=

# --- Market data ---
MARKET_DATA_TIMEOUT_SECONDS=30      # bound external provider calls (CCXT/yfinance/Alpaca)

# --- AI (Phase 6): both options are FREE ---
#   gemini  -> free API key from https://aistudio.google.com/apikey  (set GEMINI_API_KEY)
#   ollama  -> fully local, no key; install Ollama + `ollama pull llama3.1` and set provider=ollama
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
OLLAMA_BASE_URL=http://localhost:11434
AI_DEFAULT_PROVIDER=gemini          # gemini | ollama

# --- Market data: crypto (CCXT) + equities (yfinance) need NO key and work out of the box.
# --- Alpaca is optional (free paper keys at https://alpaca.markets) for equities/live seam.
ALPACA_API_KEY=
ALPACA_API_SECRET=
