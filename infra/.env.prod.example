# Production environment template. Copy to infra/.env.prod and fill in.
# NEVER commit the real .env.prod (gitignored as .env.*).

# Public domain (Caddy issues TLS for it).
DOMAIN=trade.example.com

APP_ENV=production
LOG_JSON=true
COOKIE_SECURE=true

# Generate: python -c "import secrets;print(secrets.token_urlsafe(48))"
APP_SECRET_KEY=
# Generate: python -c "import base64,nacl.utils;print(base64.b64encode(nacl.utils.random(32)).decode())"
BROKER_CRED_KEY=

# Same-origin in prod (Caddy serves api + web under DOMAIN).
CORS_ALLOW_ORIGINS=https://trade.example.com

# Internal service URLs (compose network).
DATABASE_URL=postgresql+asyncpg://trading:CHANGE_ME@db:5432/trading
REDIS_URL=redis://redis:6379/0
POSTGRES_USER=trading
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=trading

SENTRY_DSN=
METRICS_ENABLED=true

# AI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
AI_DEFAULT_PROVIDER=gemini
OLLAMA_BASE_URL=http://localhost:11434

# Market data / brokers (BYO keys)
ALPACA_API_KEY=
ALPACA_API_SECRET=

# Live trading stays OFF until the full control stack is in place.
LIVE_TRADING_ENABLED=false

# Observability
GRAFANA_PASSWORD=change-me

# Backups (restic -> Backblaze B2 / Cloudflare R2 / S3)
RESTIC_REPOSITORY=
RESTIC_PASSWORD=
